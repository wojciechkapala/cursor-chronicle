{
  "name": "cursor-chronicle",
  "version": "0.3.1",
  "description": "MCP server that pipes Codex Chronicle's screen-recording memory into Cursor.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Wojciech Kapała",
    "email": "wojtek@botmate.pl",
    "url": "https://github.com/wojciechkapala"
  },
  "homepage": "https://github.com/wojciechkapala/cursor-chronicle",
  "repository": {
    "type": "git",
    "url": "https://github.com/wojciechkapala/cursor-chronicle.git"
  },
  "keywords": [
    "cursor",
    "mcp",
    "model-context-protocol",
    "codex",
    "chronicle",
    "context",
    "memory",
    "screen-recording",
    "recall"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "cursor-chronicle": "src/server.js"
